// hackmap-next/prisma/schema.prisma
// Run: npx prisma generate && npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Required for Supabase/PgBouncer
}

// ─── Auth (NextAuth.js Adapter tables) ────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core User Model ──────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts              Account[]
  sessions              Session[]
  savedHackathons       SavedHackathon[]
  notificationPrefs     NotificationPreference?
  emailDigestLogs       EmailDigestLog[]

  @@index([email])
}

// ─── Saved Hackathons (Bookmarks) ─────────────────────────────────────────────

model SavedHackathon {
  id           String   @id @default(cuid())
  userId       String
  hackathonId  String   // External ID from scraper (e.g. "devpost-xyz")
  hackathonUrl String
  name         String
  platform     String
  startDate    DateTime?
  endDate      DateTime?
  prize        Int      @default(0)
  tags         String[] // PostgreSQL array
  country      String?
  savedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hackathonId]) // Prevent duplicate saves
  @@index([userId])
  @@index([hackathonId])
}

// ─── Notification Preferences ────────────────────────────────────────────────

model NotificationPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  emailEnabled          Boolean  @default(false)
  // Stored as PostgreSQL text array, e.g. ["AI/ML", "Web3", "FinTech"]
  interestedCategories  String[]
  digestFrequency       DigestFrequency @default(WEEKLY)
  lastDigestSentAt      DateTime?
  updatedAt             DateTime @updatedAt @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([emailEnabled]) // Used by cron to filter users
}

// ─── Email Digest Audit Log ──────────────────────────────────────────────────

model EmailDigestLog {
  id            String   @id @default(cuid())
  userId        String
  sentAt        DateTime @default(now())
  hackathonIds  String[] // IDs of hackathons included in this digest
  status        EmailStatus @default(SENT)
  errorMessage  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sentAt])
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum DigestFrequency {
  WEEKLY
  BIWEEKLY
}

enum EmailStatus {
  SENT
  FAILED
  SKIPPED
}
